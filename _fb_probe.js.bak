const https=require("https"), crypto=require("crypto");
const key=require("./hoojecalendar-firebase-adminsdk-fbsvc-cf845ce323.json");
const PROJECT=key.project_id;
function b64url(b){return Buffer.from(b).toString("base64").replace(/=/g,"").replace(/\+/g,"-").replace(/\//g,"_");}
function req(opts,body){return new Promise((res,rej)=>{const r=https.request(opts,x=>{let d="";x.on("data",c=>d+=c);x.on("end",()=>res({status:x.statusCode,body:d}));});r.on("error",rej);if(body)r.write(body);r.end();});}
async function getToken(){
  const now=Math.floor(Date.now()/1000);
  const h=b64url(JSON.stringify({alg:"RS256",typ:"JWT"}));
  const c=b64url(JSON.stringify({iss:key.client_email,scope:"https://www.googleapis.com/auth/datastore",aud:"https://oauth2.googleapis.com/token",iat:now,exp:now+3600}));
  const sig=b64url(crypto.sign("RSA-SHA256",Buffer.from(h+"."+c),key.private_key));
  const jwt=h+"."+c+"."+sig;
  const body="grant_type=urn:ietf:params:oauth:grant-type:jwt-bearer&assertion="+jwt;
  const r=await req({host:"oauth2.googleapis.com",path:"/token",method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded","Content-Length":Buffer.byteLength(body)}},body);
  return JSON.parse(r.body).access_token;
}
async function fs(method,path,token,doc){
  const base="/v1/projects/"+PROJECT+"/databases/(default)/documents"+path;
  const body=doc?JSON.stringify(doc):null;
  const headers={"Authorization":"Bearer "+token};
  if(body){headers["Content-Type"]="application/json";headers["Content-Length"]=Buffer.byteLength(body);}
  return req({host:"firestore.googleapis.com",path:base,method,headers},body);
}
(async()=>{
  try{
    const token=await getToken();
    if(!token){console.log("TOKEN_FAIL");return;}
    console.log("토큰 발급 OK");
    let r=await fs("PATCH","/_cowork_test/ping",token,{fields:{msg:{stringValue:"클로드가 코워크 REST로 씀"},at:{stringValue:new Date().toISOString()}}});
    console.log("쓰기:",r.status);
    r=await fs("GET","/_cowork_test/ping",token);
    console.log("읽기:",r.status,JSON.parse(r.body).fields?.msg?.stringValue);
    r=await fs("DELETE","/_cowork_test/ping",token);
    console.log("삭제:",r.status);
    console.log(r.status<300?"✅ 코워크 ↔ 대표님 Firestore 완전 연결됨":"⚠ 확인 필요");
  }catch(e){console.log("ERR",e.message);}
})();
